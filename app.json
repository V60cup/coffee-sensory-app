{
  "expo": {
    "name": "Ensamble",
    "slug": "ensamble",
    "scheme": "ensamble",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tuempresa.ensamble"
    },
    "android": {
      "package": "com.tuempresa.ensamble",
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F2"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    }
  }
}
